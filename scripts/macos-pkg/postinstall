#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname "$0")" && pwd)"

if [[ -x "$SCRIPT_DIR/installer-session-helper.sh" ]]; then
  "$SCRIPT_DIR/installer-session-helper.sh" prepare-app-for-sparkle-updates "/Applications/OnlyMacs.app"
  "$SCRIPT_DIR/installer-session-helper.sh" install-launch-once "/Applications/OnlyMacs.app" "--onlymacs-apply-installer-selections"
else
  /usr/bin/open -a "/Applications/OnlyMacs.app" --args --onlymacs-apply-installer-selections >/dev/null 2>&1 || true
fi

exit 0
