{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://onlymacs.local/proto/schemas/auth.start.v1.json",
  "title": "auth.start v1",
  "type": "object",
  "required": ["v", "type", "id", "token", "role"],
  "additionalProperties": false,
  "properties": {
    "v": {
      "type": "string",
      "const": "v1"
    },
    "type": {
      "type": "string",
      "const": "auth.start"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "token": {
      "type": "string",
      "minLength": 1
    },
    "role": {
      "type": "string",
      "enum": ["requester", "provider"]
    }
  }
}

