{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "provider.register.v1",
  "type": "object",
  "required": ["provider"],
  "properties": {
    "provider": {
      "type": "object",
      "required": ["id", "name", "models"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string" },
        "modes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "slots": {
          "type": "object",
          "required": ["free", "total"],
          "properties": {
            "free": { "type": "integer", "minimum": 0 },
            "total": { "type": "integer", "minimum": 0 }
          }
        },
        "models": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "name", "slots_free", "slots_total"],
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "slots_free": { "type": "integer", "minimum": 0 },
              "slots_total": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    }
  }
}
