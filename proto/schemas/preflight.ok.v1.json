{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "preflight.ok.v1",
  "type": "object",
  "required": ["requested_model", "resolved_model", "available", "providers", "available_models", "totals"],
  "properties": {
    "requested_model": { "type": "string" },
    "resolved_model": { "type": "string" },
    "available": { "type": "boolean" },
    "providers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "status", "matching_models", "slots"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "status": { "type": "string" },
          "matching_models": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "name", "slots_free", "slots_total"],
              "properties": {
                "id": { "type": "string" },
                "name": { "type": "string" },
                "slots_free": { "type": "integer", "minimum": 0 },
                "slots_total": { "type": "integer", "minimum": 0 }
              }
            }
          },
          "slots": {
            "type": "object",
            "required": ["free", "total"],
            "properties": {
              "free": { "type": "integer", "minimum": 0 },
              "total": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    },
    "available_models": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "slots_free", "slots_total"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "slots_free": { "type": "integer", "minimum": 0 },
          "slots_total": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "totals": {
      "type": "object",
      "required": ["providers", "slots_free", "slots_total"],
      "properties": {
        "providers": { "type": "integer", "minimum": 0 },
        "slots_free": { "type": "integer", "minimum": 0 },
        "slots_total": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
